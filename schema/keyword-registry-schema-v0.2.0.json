  "validation": {
    "rules": {
      "aliasMinLength": 2,
      "aliasMaxLength": 50,
      "descriptionMinLength": 10,
      "descriptionMaxLength": 255,
      "customFieldPerEntry": 1,
      "requiredBaseFields": [
        "id",
        "aliases",
        "type",
        "description"
      ]
    },
    "classificationValidation": {
      "enabled": true,
      "rules": [
        {
          "rule": "VALID_CLASSIFICATION_TAG",
          "description": "Entry must belong to a valid classification group",
          "validTags": [
            "work",
            "person",
            "tool",
            "interest",
            "project",
            "location",
            "verb",
            "adverb",
            "animal",
            "language",
            "name",
            "brand",
            "colour",
            "library",
            "framework"
          ]
        },
        {
          "rule": "TYPE_ENUM_MATCH",
          "description": "Type field must match the group's allowed enum values"
        },
        {
          "rule": "GROUP_CONSISTENCY",
          "description": "Entry properties must be consistent with group schema"
        }
      ]
    },
    "errorMessages": {
      "INVALID_ID": "ID must match pattern for the specific group namespace",
      "DUPLICATE_ID": "ID already exists in this group namespace",
      "ALIAS_TOO_SHORT": "Alias must be at least 2 characters",
      "ALIAS_TOO_LONG": "Alias must not exceed 50 characters",
      "MISSING_REQUIRED_FIELD": "Required field missing: {field}",
      "INVALID_ENUM": "Value must be one of: {values}",
      "CUSTOM_FIELD_MISMATCH": "Custom field type does not match schema definition",
      "DESCRIPTION_TOO_LONG": "Description exceeds 255 characters",
      "DUPLICATE_ALIAS": "This alias is already used in namespace: {group}",
      "INVALID_TYPE": "Field type mismatch. Expected {type}, got {actual}",
      "INVALID_PATTERN": "Value does not match the required pattern for this field",
      "BROKEN_RELATIONSHIP": "Referenced ID does not exist in the registry",
      "INVALID_CLASSIFICATION_TAG": "Classification tag '{tag}' is not recognized",
      "TYPE_MISMATCH_WITH_GROUP": "Type '{type}' is not valid for group '{group}'",
      "MISSING_CLASSIFICATION_TAG": "Entry must specify a valid classification tag"
    }
  },

  "searchIndex": {
    "enabled": true,
    "description": "Enables fast keyword search across all groups by classification",
    "indexedFields": [
      "id",
      "aliases",
      "classificationTag",
      "description"
    ],
    "searchStrategies": [
      {
        "strategy": "byClassification",
        "description": "Search keywords by classification type (work, person, tool, etc.)"
      },
      {
        "strategy": "byAlias",
        "description": "Search by exact or fuzzy alias matching"
      },
      {
        "strategy": "byGroup",
        "description": "Search within specific group namespace"
      },
      {
        "strategy": "crossGroup",
        "description": "Search across multiple groups by classification"
      }
    ]
  }
}
